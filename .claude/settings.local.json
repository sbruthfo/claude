{
  "permissions": {
    "allow": [
      "Bash(pip show *)",
      "Bash(python3 -c \"import playwright\")",
      "Bash(chromium --headless --no-sandbox --screenshot=/tmp/preview.png --window-size=1280,900 \"file:///mnt/chromeos/MyFiles/her-equity-collective/index.html\")",
      "Bash(chromium --headless --no-sandbox --screenshot=/tmp/preview_scroll.png --window-size=1280,3500 \"file:///mnt/chromeos/MyFiles/her-equity-collective/index.html\")",
      "Read(//tmp/**)",
      "Bash(chromium *)"
    ]
  },
  "PreToolUse": [
    {
      "matcher": "Read",
      "hooks": [
        {
          "type": "command",
          "command": "node /home/hooks/read_hook.js"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "node /home/hooks/format_hook.js"
        }
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const f=(JSON.parse(d).tool_input||{}).file_path||'';if(/\\.(html|css)$/.test(f)){require('child_process').execSync('prettier --write '+JSON.stringify(f),{stdio:'inherit'})}})\" 2>/dev/null || true"
        }
      ]
    }
  ]
}